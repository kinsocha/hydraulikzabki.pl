---
import { site } from '../config/site';
---

<footer>
  <div class="container footer-grid">
    <div>
      <h3>Hydraulik Ząbki</h3>
      <p>Udrażnianie rur i kanalizacji, przepychanie zlewów, WC, wanien, brodzików, odpływów pralki, zmywarki oraz pionów kanalizacyjnych.</p>
    </div>
    <div>
      <h4>Kontakt</h4>
      <ul>
        <li><a href={`tel:${site.phoneTel}`}>{site.phone}</a></li>
        <li>Ząbki i okolice</li>
        <li>Warszawa — pobliskie dzielnice</li>
      </ul>
    </div>
    <div>
      <h4>Usługi</h4>
      <ul>
        <li>Udrażnianie rur</li>
        <li>Przepychanie kanalizacji</li>
        <li>Sprężyna elektryczna</li>
        <li>Zatory w łazience i kuchni</li>
      </ul>
    </div>
  </div>
  <div class="container copy">© Hydraulik Ząbki. Ząbki i okolice.</div>
</footer>
